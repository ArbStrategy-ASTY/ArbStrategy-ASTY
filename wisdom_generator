<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ASTY Wisdom Generator</title>
  <style>
    :root {
      --bg1: #07111f;
      --bg2: #0b1830;
      --panel: rgba(10, 18, 34, 0.82);
      --border: rgba(133, 87, 255, 0.22);
      --text: #e9efff;
      --muted: #9fb2d9;
      --purple: #8b5cf6;
      --purple-2: #a855f7;
      --cyan: #22d3ee;
      --red: #ff5d73;
      --shadow: 0 0 30px rgba(139, 92, 246, 0.18);
      --radius: 22px;
      --transition: 0.28s ease;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: Inter, Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.08), transparent 22%),
        radial-gradient(circle at 80% 30%, rgba(168, 85, 247, 0.11), transparent 26%),
        radial-gradient(circle at 50% 80%, rgba(139, 92, 246, 0.08), transparent 28%),
        linear-gradient(180deg, var(--bg1), var(--bg2));
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: radial-gradient(circle at center, black 40%, transparent 100%);
      opacity: 0.35;
    }

    .wrap {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 32px 18px;
    }

    .card {
      width: 100%;
      max-width: 900px;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      padding: 34px 28px 28px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(135deg, rgba(139, 92, 246, 0.10), transparent 35%),
        linear-gradient(315deg, rgba(34, 211, 238, 0.06), transparent 30%);
    }

    .header {
      position: relative;
      z-index: 1;
      text-align: center;
      margin-bottom: 26px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--cyan);
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 10px;
      opacity: 0.9;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--cyan);
      box-shadow: 0 0 12px rgba(34, 211, 238, 0.75);
      animation: pulse 1.8s infinite;
    }

    h1 {
      margin: 0;
      font-size: clamp(30px, 5vw, 52px);
      line-height: 1.02;
      letter-spacing: 0.03em;
      font-weight: 800;
      text-transform: uppercase;
      text-shadow: 0 0 18px rgba(139, 92, 246, 0.22);
    }

    .sub {
      margin: 12px auto 0;
      max-width: 620px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .output-box {
      position: relative;
      z-index: 1;
      min-height: 210px;
      border-radius: 20px;
      padding: 28px 24px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015)),
        rgba(4, 10, 22, 0.72);
      border: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 24px rgba(0,0,0,0.18);
      transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    }

    .output-box.win {
      border-color: rgba(139, 92, 246, 0.28);
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 30px rgba(139, 92, 246, 0.16);
    }

    .output-box.loss {
      border-color: rgba(255, 93, 115, 0.30);
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 26px rgba(255, 93, 115, 0.14);
    }

    .output-box.fade {
      opacity: 0.55;
      transform: scale(0.994);
    }

    .output {
      margin: 0;
      white-space: pre-line;
      font-size: clamp(24px, 3vw, 36px);
      line-height: 1.45;
      font-weight: 700;
      letter-spacing: 0.01em;
      text-shadow: 0 0 16px rgba(139, 92, 246, 0.12);
      max-width: 720px;
      word-break: break-word;
    }

    .output.awaiting {
      color: var(--muted);
      font-weight: 600;
      text-shadow: none;
    }

    .cursor {
      display: inline-block;
      width: 0.65ch;
      text-align: left;
      animation: blink 0.75s step-end infinite;
      color: rgba(255,255,255,0.9);
    }

    .controls {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      margin-top: 24px;
    }

    .btn {
      appearance: none;
      border: 0;
      outline: 0;
      cursor: pointer;
      padding: 16px 26px;
      min-width: 240px;
      border-radius: 999px;
      color: white;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 13px;
      background:
        linear-gradient(90deg, rgba(139, 92, 246, 0.95), rgba(168, 85, 247, 0.95));
      box-shadow:
        0 0 24px rgba(139, 92, 246, 0.28),
        inset 0 0 0 1px rgba(255,255,255,0.1);
      transition: transform var(--transition), box-shadow var(--transition), filter var(--transition), opacity var(--transition);
    }

    .btn:hover {
      transform: translateY(-1px) scale(1.01);
      box-shadow:
        0 0 34px rgba(139, 92, 246, 0.38),
        inset 0 0 0 1px rgba(255,255,255,0.12);
      filter: brightness(1.04);
    }

    .btn:active {
      transform: translateY(0) scale(0.995);
    }

    .btn:disabled {
      opacity: 0.68;
      cursor: not-allowed;
    }

    .stats {
      position: relative;
      z-index: 1;
      margin-top: 22px;
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .pill {
      padding: 10px 14px;
      border-radius: 999px;
      font-size: 12px;
      color: var(--muted);
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      letter-spacing: 0.04em;
    }

    .shake {
      animation: shake 0.32s ease;
    }

    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.25); opacity: 0.7; }
    }

    @keyframes shake {
      0% { transform: translateX(0); }
      20% { transform: translateX(-5px); }
      40% { transform: translateX(4px); }
      60% { transform: translateX(-3px); }
      80% { transform: translateX(2px); }
      100% { transform: translateX(0); }
    }

    @media (max-width: 640px) {
      .card {
        padding: 26px 18px 20px;
      }

      .output-box {
        min-height: 190px;
        padding: 22px 16px;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="card">
      <div class="header">
        <div class="eyebrow">
          <span class="dot"></span>
          ASTY SIGNAL INTERFACE
        </div>
        <h1>ASTY Wisdom Generator</h1>
        <p class="sub">Receive a transmission. Or get rejected by the system.</p>
      </div>

      <div id="outputBox" class="output-box">
        <p id="output" class="output awaiting">Awaiting ASTY transmission…</p>
      </div>

      <div class="controls">
        <button id="generateBtn" class="btn">Receive Wisdom</button>
      </div>

      <div class="stats">
        <div class="pill">50 / 50 transmission logic</div>
        <div class="pill">Typewriter enabled</div>
        <div class="pill">🟣 Wisdom or ❌ Rejection</div>
      </div>
    </section>
  </div>

  <script>
    const winMessages = [
      "🟣 Capital follows performance.",
      "🟣 Volume is the engine.",
      "🟣 The system does not wait.",
      "🟣 Efficiency decides allocation.",
      "🟣 Liquidity follows proof.",
      "🟣 Strong pools earn more.",
      "🟣 Performance is the only argument.",
      "🟣 Burn is the memory of activity.",
      "🟣 Capital respects momentum.",
      "🟣 The flow rewards conviction.",
      "🟣 The system scales through action.",
      "🟣 Real strength compounds quietly."
    ];

    const lossMessages = [
      "❌ Your wallet was scanned. Not enough $ASTY detected.",
      "❌ Wisdom denied. Minimum $ASTY aura not reached.",
      "❌ System review complete. Holdings are emotionally insufficient.",
      "❌ Transmission failed. Your wallet looks like a spectator.",
      "❌ Access denied. Please accumulate more conviction.",
      "❌ ASTY checked your bag. It was mostly vibes.",
      "❌ Not enough $ASTY to unlock premium enlightenment.",
      "❌ Nice try. The system prefers stronger holders.",
      "❌ Wallet scan failed. Exposure level: concerning.",
      "❌ The signal saw your balance and lost interest.",
      "❌ Transmission blocked. Portfolio too lightweight.",
      "❌ ASTY reviewed your wallet and suggested more accumulation."
    ];

    const output = document.getElementById("output");
    const outputBox = document.getElementById("outputBox");
    const button = document.getElementById("generateBtn");

    let typingTimeout;
    let loadingTimeout;

    function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    function randomItem(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function typeText(text, mode = "win", speed = 32) {
      return new Promise(resolve => {
        clearTimeout(typingTimeout);
        output.classList.remove("awaiting");
        output.textContent = "";

        let i = 0;

        function tick() {
          if (i <= text.length) {
            const visible = text.slice(0, i);
            output.innerHTML = `${escapeHtml(visible)}<span class="cursor">|</span>`;
            i++;
            typingTimeout = setTimeout(tick, speed);
          } else {
            output.innerHTML = `${escapeHtml(text)}<span class="cursor">|</span>`;
            resolve();
          }
        }

        tick();
      });
    }

    function escapeHtml(str) {
      return str
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    async function generateTransmission() {
      button.disabled = true;

      outputBox.classList.add("fade");
      outputBox.classList.remove("win", "loss", "shake");

      await sleep(220);

      output.classList.remove("awaiting");
      output.textContent = "Receiving transmission...";

      outputBox.classList.remove("fade");

      await sleep(420);

      const isWin = Math.random() < 0.5;
      const message = isWin ? randomItem(winMessages) : randomItem(lossMessages);
      const mode = isWin ? "win" : "loss";

      outputBox.classList.remove("win", "loss");
      outputBox.classList.add(mode);

      if (!isWin) {
        outputBox.classList.add("shake");
        setTimeout(() => outputBox.classList.remove("shake"), 340);
      }

      const speed = isWin ? 34 : 26;
      await typeText(message, mode, speed);

      button.disabled = false;
    }

    button.addEventListener("click", generateTransmission);
  </script>
</body>
</html>
