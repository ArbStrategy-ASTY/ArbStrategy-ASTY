<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ASTY Wisdom Generator</title>
  <style>
    :root {
      --bg1: #07111f;
      --bg2: #0b1830;
      --panel: rgba(10, 18, 34, 0.82);
      --border: rgba(133, 87, 255, 0.22);
      --text: #e9efff;
      --muted: #9fb2d9;
      --purple: #8b5cf6;
      --purple-2: #a855f7;
      --cyan: #22d3ee;
      --red: #ff5d73;
      --shadow: 0 0 30px rgba(139, 92, 246, 0.18);
      --radius: 22px;
      --transition: 0.28s ease;
    }

    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: Inter, Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.08), transparent 22%),
        radial-gradient(circle at 80% 30%, rgba(168, 85, 247, 0.11), transparent 26%),
        radial-gradient(circle at 50% 80%, rgba(139, 92, 246, 0.08), transparent 28%),
        linear-gradient(180deg, var(--bg1), var(--bg2));
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: radial-gradient(circle at center, black 40%, transparent 100%);
      opacity: 0.35;
    }

    .wrap {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 32px 18px;
    }

    .card {
      width: 100%;
      max-width: 920px;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      padding: 34px 28px 28px;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(135deg, rgba(139, 92, 246, 0.10), transparent 35%),
        linear-gradient(315deg, rgba(34, 211, 238, 0.06), transparent 30%);
    }

    .header {
      position: relative;
      z-index: 1;
      text-align: center;
      margin-bottom: 26px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--cyan);
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: 10px;
      opacity: 0.9;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--cyan);
      box-shadow: 0 0 12px rgba(34, 211, 238, 0.75);
      animation: pulseDot 1.8s infinite;
    }

    h1 {
      margin: 0;
      font-size: clamp(30px, 5vw, 52px);
      line-height: 1.02;
      letter-spacing: 0.03em;
      font-weight: 800;
      text-transform: uppercase;
      text-shadow: 0 0 18px rgba(139, 92, 246, 0.22);
    }

    .sub {
      margin: 12px auto 0;
      max-width: 700px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.7;
    }

    .output-box {
      position: relative;
      z-index: 1;
      min-height: 210px;
      border-radius: 20px;
      padding: 28px 24px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015)),
        rgba(4, 10, 22, 0.72);
      border: 1px solid rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 24px rgba(0,0,0,0.18);
      transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition), opacity var(--transition);
    }

    .output-box.win {
      border-color: rgba(139, 92, 246, 0.28);
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 30px rgba(139, 92, 246, 0.16);
    }

    .output-box.loss {
      border-color: rgba(255, 93, 115, 0.30);
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 26px rgba(255, 93, 115, 0.14);
    }

    .output-box.fade {
      opacity: 0.55;
      transform: scale(0.994);
    }

    .output {
      margin: 0;
      white-space: pre-line;
      font-size: clamp(24px, 3vw, 36px);
      line-height: 1.45;
      font-weight: 700;
      letter-spacing: 0.01em;
      text-shadow: 0 0 16px rgba(139, 92, 246, 0.12);
      max-width: 720px;
      word-break: break-word;
    }

    .output.awaiting {
      color: var(--muted);
      font-weight: 600;
      text-shadow: none;
    }

    .cursor {
      display: inline-block;
      width: 0.65ch;
      text-align: left;
      animation: blink 0.75s step-end infinite;
      color: rgba(255,255,255,0.9);
    }

    .controls {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .btn {
      appearance: none;
      border: 0;
      outline: 0;
      cursor: pointer;
      padding: 16px 26px;
      min-width: 220px;
      border-radius: 999px;
      color: white;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 13px;
      background:
        linear-gradient(90deg, rgba(139, 92, 246, 0.95), rgba(168, 85, 247, 0.95));
      box-shadow:
        0 0 24px rgba(139, 92, 246, 0.28),
        inset 0 0 0 1px rgba(255,255,255,0.1);
      transition: transform var(--transition), box-shadow var(--transition), filter var(--transition), opacity var(--transition);
    }

    .btn:hover {
      transform: translateY(-1px) scale(1.01);
      box-shadow:
        0 0 34px rgba(139, 92, 246, 0.38),
        inset 0 0 0 1px rgba(255,255,255,0.12);
      filter: brightness(1.04);
    }

    .btn:active {
      transform: translateY(0) scale(0.995);
    }

    .btn:disabled {
      opacity: 0.68;
      cursor: not-allowed;
    }

    .copy-btn {
      background:
        linear-gradient(90deg, rgba(34, 211, 238, 0.90), rgba(139, 92, 246, 0.90));
      min-width: 180px;
      box-shadow:
        0 0 20px rgba(34, 211, 238, 0.22),
        inset 0 0 0 1px rgba(255,255,255,0.1);
    }

    .copy-btn.copied {
      filter: brightness(1.08);
      box-shadow:
        0 0 28px rgba(34, 211, 238, 0.30),
        inset 0 0 0 1px rgba(255,255,255,0.12);
    }

    .wolf-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      margin-top: 30px;
      min-height: 210px;
    }

    .wolf-glow {
      position: absolute;
      width: min(320px, 70vw);
      height: min(320px, 70vw);
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(139, 92, 246, 0.30) 0%, rgba(34, 211, 238, 0.16) 38%, rgba(139, 92, 246, 0.02) 68%, transparent 76%);
      filter: blur(18px);
      animation: wolfGlow 2.6s ease-in-out infinite;
      pointer-events: none;
    }

    .wolf {
      position: relative;
      width: min(300px, 72vw);
      max-width: 300px;
      height: auto;
      object-fit: contain;
      filter:
        drop-shadow(0 0 18px rgba(139, 92, 246, 0.35))
        drop-shadow(0 0 35px rgba(34, 211, 238, 0.14));
      animation: wolfPulse 2.6s ease-in-out infinite;
      user-select: none;
      -webkit-user-drag: none;
    }

    .copy-hint {
      position: relative;
      z-index: 1;
      margin-top: 14px;
      text-align: center;
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.03em;
      min-height: 18px;
    }

    .shake {
      animation: shake 0.32s ease;
    }

    @keyframes blink {
      0%, 49% { opacity: 1; }
      50%, 100% { opacity: 0; }
    }

    @keyframes pulseDot {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.25); opacity: 0.7; }
    }

    @keyframes wolfPulse {
      0%, 100% {
        transform: scale(1);
        opacity: 1;
      }
      50% {
        transform: scale(1.04);
        opacity: 0.96;
      }
    }

    @keyframes wolfGlow {
      0%, 100% {
        transform: scale(1);
        opacity: 0.72;
      }
      50% {
        transform: scale(1.08);
        opacity: 1;
      }
    }

    @keyframes shake {
      0% { transform: translateX(0); }
      20% { transform: translateX(-5px); }
      40% { transform: translateX(4px); }
      60% { transform: translateX(-3px); }
      80% { transform: translateX(2px); }
      100% { transform: translateX(0); }
    }

    @media (max-width: 640px) {
      .card {
        padding: 26px 18px 20px;
      }

      .output-box {
        min-height: 190px;
        padding: 22px 16px;
      }

      .btn, .copy-btn {
        width: 100%;
        min-width: 0;
      }

      .wolf-wrap {
        min-height: 180px;
      }
    }
  </style>
