    function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    function randomItem(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function escapeHtml(str) {
      return str
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;");
    }

    async function typeText(text, speed = 32) {
      isTyping = true;
      output.classList.remove("awaiting");
      output.textContent = "";

      for (let i = 0; i <= text.length; i++) {
        const visible = text.slice(0, i);
        output.innerHTML = `${escapeHtml(visible)}<span class="cursor">|</span>`;
        await sleep(speed);
      }

      output.innerHTML = `${escapeHtml(text)}<span class="cursor">|</span>`;
      isTyping = false;
    }

    async function generateTransmission() {
      if (isTyping) return;

      generateBtn.disabled = true;
      copyHint.textContent = "";

      outputBox.classList.add("fade");
      outputBox.classList.remove("win", "loss", "shake");

      await sleep(220);

      output.classList.remove("awaiting");
      output.textContent = "Receiving transmission...";

      outputBox.classList.remove("fade");

      await sleep(420);

      const isWin = Math.random() < 0.5;
      const message = isWin ? randomItem(winMessages) : randomItem(lossMessages);
      currentPlainText = message;

      outputBox.classList.remove("win", "loss");
      outputBox.classList.add(isWin ? "win" : "loss");

      if (!isWin) {
        outputBox.classList.add("shake");
        setTimeout(() => outputBox.classList.remove("shake"), 340);
      }

      await typeText(message, isWin ? 34 : 26);

      generateBtn.disabled = false;
    }

    async function copyCurrentText() {
      if (isTyping) return;

      try {
        await navigator.clipboard.writeText(currentPlainText);
        copyBtn.classList.add("copied");
        copyHint.textContent = "Copied to clipboard.";
        setTimeout(() => {
          copyBtn.classList.remove("copied");
        }, 900);
      } catch (err) {
        copyHint.textContent = "Copy failed. Clipboard access was blocked.";
      }
    }

    generateBtn.addEventListener("click", generateTransmission);
    copyBtn.addEventListener("click", copyCurrentText);
